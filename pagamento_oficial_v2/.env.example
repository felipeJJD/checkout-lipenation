# ===== pagamento_oficial_v2 (backend Next.js) =====
# Copie para `.env` (ou configure no painel do Railway/Vercel) e preencha.
# NUNCA commitar o `.env` real — só este exemplo.

# Chave SECRETA da Pagar.me (sk_...). Obrigatória.
# O backend recusa requisições se ausente/inválida. NÃO usar a chave de
# outra conta — usar a chave da conta de produção da titular.
PAGARME_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Origem do frontend permitida pelo CORS (allowlist).
# Ex.: https://dshub.com.br
FRONTEND_URL_ALLOWED=https://exemplo.com.br

# Tópico do ntfy.sh para notificação de venda. Opcional.
# Se ausente, as notificações são simplesmente puladas.
# Usar um tópico PRIVADO/aleatório — qualquer um que saiba o tópico lê as notificações.
NTFY_TOPIC=

# Força respostas de pagamento simuladas (sem chamar a Pagar.me).
# Deixar vazio/false em produção.
USE_PAYMENT_SIMULATION=

# Porta do servidor (opcional; default da plataforma).
PORT=3000
